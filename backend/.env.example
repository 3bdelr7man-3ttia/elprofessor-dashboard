# --- Core security (set REAL values in production) ---
# JWT signing key. REQUIRED in prod: if unset the app generates an ephemeral key
# (logs a loud warning) and ALL issued JWTs are invalidated on every restart.
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars

DATABASE_URL=sqlite:///elprofessor.db

# Comma-separated CORS allow-list. If unset, defaults to the dashboard + brand
# origins (dashboard.elprofessor.net, elprofessor.net, www.elprofessor.net,
# api.elprofessor.net). For local dev, include your Vite/CRA origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

FLASK_DEBUG=false
PORT=5000

# --- Admin account ---
# On boot: if an admin with ADMIN_EMAIL does NOT exist, it is created with
# ADMIN_PASSWORD. If it DOES exist, its password is RESET to ADMIN_PASSWORD
# (rotate the env + redeploy => password rotates). If ADMIN_PASSWORD is unset,
# NO default-password admin is seeded (a warning is logged instead).
ADMIN_EMAIL=admin@elprofessor.com
ADMIN_PASSWORD=
ADMIN_NAME=عبدالرحمن

# --- Platform <-> dashboard bridge (SSO + metrics + investor wallet mirror) ---
# Base URL of the platform API the dashboard talks to (SSO verify, metrics,
# bridge users, role control). Defaults to https://api.elprofessor.net.
PLATFORM_API_URL=https://api.elprofessor.net
# Shared service secret for the platform<->dashboard bridge endpoints
# (X-ELP-Metrics-Secret). Required for /api/platform-* and the public
# /api/investor/wallet mirror used by the platform.
METRICS_SECRET=

# --- CMS / Content + Messages (marketing site feed + contact form) ---
# Public, no-auth, cross-origin endpoints (CORS-allowed for the site origins):
#   GET  /api/content/articles?status=published   (no-store feed)
#   POST /api/messages                            (contact form)
# Admin endpoints reuse the dashboard JWT/admin auth. No extra keys are required
# beyond CORS_ORIGINS above; site origins (elprofessor.net, www.elprofessor.net)
# must be present in CORS_ORIGINS (they are in the built-in default).

# --- AI providers (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_MODEL=deepseek-chat
